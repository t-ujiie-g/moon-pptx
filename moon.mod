name = "t-ujiie-g/moon-pptx"

version = "0.5.1"

import {
  "hustcer/fzip@0.6.1",
}

readme = "README.mbt.md"

repository = "https://github.com/t-ujiie-g/moon-pptx"

license = "Apache-2.0"

keywords = [
  "pptx",
  "powerpoint",
  "ooxml",
  "office",
  "presentation",
  "builder",
]

description = "Pure-MoonBit library for reading, building, and writing PPTX (OOXML) presentations with a type-safe builder API."

options(
  source: "src",
)
