// Shared OOXML namespace URIs used by the theme parsers.

///|
/// DrawingML main namespace — the home of `a:theme`, `a:srgbClr`, and most
/// element families that appear inside theme parts. Conventionally bound to
/// the `a:` prefix.
pub let drawing_ns : String = "http://schemas.openxmlformats.org/drawingml/2006/main"
